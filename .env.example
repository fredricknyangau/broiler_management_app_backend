# =================================================================================
# BROILER FARM MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# =================================================================================
# This file contains all environment variables used by the FastAPI backend.
# Copy this file to .env and fill in your values.
#
# IMPORTANT SECURITY NOTES:
# - Never commit .env files to version control
# - Use strong, unique secrets in production
# - Generate SECRET_KEY with: python3 scripts/generate_secret.py
# =================================================================================

# ================================================================================
# APPLICATION SETTINGS
# ================================================================================

# Application name (displayed in API docs)
APP_NAME=Broiler Farm Management API

# Debug mode (True for development, False for production)
DEBUG=False

# API version prefix
API_V1_PREFIX=/api/v1

# Public API URLs consumed by external clients like the mobile app.
# These are safe to mirror into GitHub Actions or other CI systems.
# MOBILE_API_URL is the default fallback for any branch.
# MOBILE_API_URL_DEV and MOBILE_API_URL_PROD let CI choose by branch.
MOBILE_API_URL=http://localhost:8080/api/v1
MOBILE_API_URL_DEV=http://localhost:8080/api/v1
MOBILE_API_URL_PROD=https://your-production-api.com/api/v1

# Allowed CORS origins (comma-separated list in JSON format)
# Development: ["http://localhost:5173", "http://localhost:3000"]
# Production: ["https://yourdomain.com"]
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Server port (used by start.sh, defaults to 8080)
PORT=8080

# ================================================================================
# DATABASE CONFIGURATION
# ================================================================================

# PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
# Development: postgresql+asyncpg://broiler_user:broiler_pass@localhost:5432/broiler_farm_db
# Production: Use managed PostgreSQL service URL
DATABASE_URL=postgresql+asyncpg://broiler_user:broiler_pass@localhost:5432/broiler_farm_db

# PostgreSQL credentials (used by docker-compose for local development)
POSTGRES_USER=broiler_user
POSTGRES_PASSWORD=broiler_pass
POSTGRES_DB=broiler_farm_db

# ================================================================================
# REDIS CONFIGURATION
# ================================================================================

# Redis connection string
# Format: redis://host:port/db
# Development: redis://localhost:6379/0
# Production: Use managed Redis service URL
REDIS_URL=redis://localhost:6379/0

# ================================================================================
# SECURITY & AUTHENTICATION
# ================================================================================

# CRITICAL: Secret key for JWT signing (MUST be changed in production)
# Generate with: python3 scripts/generate_secret.py
# Minimum 32 characters, use a strong random string
SECRET_KEY=change-me-in-production-please-use-a-secure-random-key

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# JWT token expiration in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ================================================================================
# NOTIFICATIONS & COMMUNICATIONS
# ================================================================================

# SMS Provider API Key (optional)
SMS_PROVIDER_API_KEY=

# Africa's Talking credentials (for SMS in Kenya/Uganda/Tanzania)
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=place_holder

# Email API Key (optional, for transactional emails)
EMAIL_API_KEY=

# Push notification service key (optional)
PUSH_NOTIFICATION_KEY=

# ================================================================================
# EMAIL / SMTP CONFIGURATION
# ================================================================================

# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Email sender configuration
EMAILS_FROM_EMAIL=notifications@broiler-manager.com
EMAILS_FROM_NAME=Broiler Manager

# ================================================================================
# M-PESA PAYMENT INTEGRATION
# ================================================================================

# M-Pesa API credentials (for Kenyan mobile payments)
MPESA_CONSUMER_KEY=place_holder
MPESA_CONSUMER_SECRET=place_holder
MPESA_PASSKEY=place_holder
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/billing/mpesa/callback
# Sandbox (default). Production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# ================================================================================
# AI INTEGRATION
# ================================================================================

# AI/LLM provider (openai, gemini, etc.)
LLM_PROVIDER=gemini

# API key for LLM provider
LLM_API_KEY=

# Gemini model name (if using Google Gemini)
GEMINI_MODEL=gemini-1.5-flash

# ================================================================================
# OAUTH / SSO CONFIGURATION
# ================================================================================

# Google OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Apple Sign-In credentials
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ================================================================================
# MONITORING & ERROR TRACKING
# ================================================================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable Sentry monitoring
SENTRY_ENABLED=False

# Sentry traces sample rate (0.0 to 1.0, default 0.1 = 10%)
SENTRY_TRACES_SAMPLE_RATE=0.1

# ================================================================================
# DEPLOYMENT ENVIRONMENT
# ================================================================================

# Environment indicator (used for validation, optional)
# Values: development, staging, production
ENVIRONMENT=development

# =================================================================================
# END OF CONFIGURATION
# =================================================================================
# Notes:
# - All optional fields can be left empty if not using the feature
# - In production, ensure DEBUG=False and use secure DATABASE_URL/SECRET_KEY
# - For cloud deployments, check provider-specific environment variables
# =================================================================================
